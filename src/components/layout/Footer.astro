---
import { menuLinks } from "@/site.config";
---

<footer
	class="text-muted mt-auto flex w-full items-center justify-center pt-20 pb-4 text-center font-semibold sm:text-xs"
>
	<nav aria-label="Footer" class="sm:divide-muted flex gap-x-2 sm:gap-x-0 sm:divide-x">
		{
			menuLinks.map((link) => (
				<a class="hover:text-global-text px-4 py-2 hover:underline sm:py-0" href={link.path}>
					{link.title}
				</a>
			))
		}
	</nav>
</footer>
